	partition SalesLines = m
		mode: import
		source =
				let
				  Source = Json.Document(Web.Contents("https://dummyjson.com/carts?limit=0")),
				  ConvertedToTable = Table.FromRecords({Source}),
				  ExpandedCarts = Table.ExpandListColumn(ConvertedToTable, "carts"),
				  ExpandedCartFields = Table.ExpandRecordColumn(ExpandedCarts, "carts", {"id", "products", "total", "discountedTotal", "userId", "totalProducts", "totalQuantity"}, {"CartId", "products", "CartGrossTotal", "CartNetTotal", "ClientId", "CartProductCount", "CartQuantity"}),
				  ExpandedProducts = Table.ExpandListColumn(ExpandedCartFields, "products"),
				  ExpandedLineFields = Table.ExpandRecordColumn(ExpandedProducts, "products", {"id", "title", "price", "quantity", "total", "discountPercentage", "discountedTotal"}, {"ProductId", "ProductName", "UnitPrice", "Quantity", "GrossRevenue", "DiscountPct", "NetRevenue"}),
				  ChangedTypes = Table.TransformColumnTypes(ExpandedLineFields, {{"CartId", Int64.Type}, {"ProductId", Int64.Type}, {"ProductName", type text}, {"UnitPrice", type number}, {"Quantity", Int64.Type}, {"GrossRevenue", type number}, {"DiscountPct", type number}, {"NetRevenue", type number}, {"ClientId", Int64.Type}, {"CartGrossTotal", type number}, {"CartNetTotal", type number}, {"CartProductCount", Int64.Type}, {"CartQuantity", Int64.Type}}),
				  AddedOrderDate = Table.AddColumn(ChangedTypes, "OrderDate", each Date.AddDays(#date(2025, 1, 1), Number.Mod(([CartId] - 1) * 37, 365)), type date)
				in
				  AddedOrderDate

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

